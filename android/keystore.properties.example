# Copy to keystore.properties in this folder (android/) — do NOT commit keystore.properties.
# Generate a keystore once, then use it for all Play uploads (back it up securely).
#
# keytool -genkey -v -keystore release.keystore -alias coparse -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is relative to the android/ directory, or use an absolute path.
storeFile=release.keystore
storePassword=your-store-password
keyAlias=coparse
keyPassword=your-key-password
